{
  "name": "oura-mcp-server",
  "version": "1.0.0",
  "description": "Cloudflare Worker MCP server exposing Oura Ring health data as tools for Claude",
  "license": "MIT",
  "homepage": "https://github.com/loganmurphy/oura-mcp-server",
  "repository": {
    "type": "git",
    "url": "https://github.com/loganmurphy/oura-mcp-server.git"
  },
  "keywords": [
    "mcp",
    "oura",
    "claude",
    "cloudflare-workers",
    "health",
    "wearables"
  ],
  "private": true,
  "scripts": {
    "lint": "oxlint --config .oxlintrc.json --deny-warnings src scripts",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "connect-local": "tsx scripts/connect-local.ts",
    "reset": "rm -f .dev.vars wrangler.jsonc && echo 'Cleared .dev.vars + wrangler.jsonc. Re-run `pnpm bootstrap` to start fresh.'"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250409.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "cloudflare": "^5.2.0",
    "lefthook": "^2.1.6",
    "oxlint": "^1.61.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.10.0"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "10.x"
  },
  "volta": {
    "node": "24.11.1",
    "pnpm": "10.22.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ],
    "ignoredBuiltDependencies": [
      "lefthook"
    ]
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.4.0"
  }
}
